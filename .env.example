# TxLINE
TXLINE_API_KEY=your_txline_api_key_here

# Database (Neon / Supabase)
DATABASE_URL=postgresql://user:pass@host/bozpicks

# Redis (Upstash)
REDIS_URL=redis://default:pass@host:6379

# AI (Claude — used for match event explanations)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Neural voice for the AI Pundit (OPTIONAL — set ONE. Without any, the pundit
# falls back to the browser's built-in voice). Free-tier friendly, in order of
# how easy they are to get:
#   Groq PlayAI TTS  → https://console.groq.com/keys        (free tier, fastest to set up)
GROQ_API_KEY=
#   Deepgram Aura-2  → https://console.deepgram.com          ($200 free credit, very natural)
DEEPGRAM_API_KEY=
#   ElevenLabs       → https://elevenlabs.io/app/settings/api-keys  (10k chars/mo free, top quality)
ELEVENLABS_API_KEY=
#   OpenAI TTS       → https://platform.openai.com/api-keys  (paid, cheap, excellent)
OPENAI_API_KEY=
# Optional: override the default voice for whichever provider is active.
#   Groq: Fritz-PlayAI · Deepgram: aura-2-orion-en · OpenAI: onyx · ElevenLabs: <voice_id>
TTS_VOICE=

# Agent config (optional overrides)
SHARP_THRESHOLD=0.10
SHARP_WINDOW_MS=120000

# Subdomains (set in Vercel env vars)
AGENT_DOMAIN=agent.bozpicks.com
SETTLE_DOMAIN=settle.bozpicks.com

# Debug
LOG_EVENTS=false

# Solana
NEXT_PUBLIC_SOLANA_NETWORK=devnet
SETTLEMENT_KEEPER_KEYPAIR=[]   # JSON array of bytes
BOZPICKS_PROGRAM_ID=GxH4pi5NY8qKd9vNuYqYT6UWW7jTsjaCFFy233KFTNYh
