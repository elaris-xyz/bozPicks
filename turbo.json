{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "REDIS_URL",
    "ANTHROPIC_API_KEY",
    "TXLINE_API_KEY",
    "SHARP_THRESHOLD",
    "SHARP_WINDOW_MS",
    "LOG_EVENTS",
    "NEXT_PUBLIC_SOLANA_NETWORK",
    "NEXT_PUBLIC_RPC_URL",
    "BOZPICKS_PROGRAM_ID",
    "SETTLEMENT_KEEPER_KEYPAIR",
    "SOLANA_RPC",
    "TREASURY_SECRET_KEY",
    "TREASURY_LAMPORTS_PER_USD",
    "NEXT_PUBLIC_TREASURY_ADDRESS",
    "NEXT_PUBLIC_LAMPORTS_PER_USD"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "type-check": {
      "dependsOn": ["^build"]
    },
    "test": {}
  }
}
